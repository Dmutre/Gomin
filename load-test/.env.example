# Gomin load test — copy to .env and adjust values before running
#
# Usage:
#   k6 run --env-file load-test/.env load-test/gomin-load-test.js
#   k6 run -e BASE_URL=https://api.1.2.3.4.nip.io load-test/gomin-load-test.js

# ── Target ────────────────────────────────────────────────────────────────────
# HTTP API host — /api prefix is appended automatically
BASE_URL=http://localhost:3000

# WebSocket host — derived from BASE_URL if omitted (http→ws, https→wss)
# WS_URL=ws://localhost:3000

# ── Setup phase ───────────────────────────────────────────────────────────────
# Number of users registered once before the test starts.
# Must be >= 2. Increase to match SPIKE_VUS for a cleaner test.
SETUP_USERS=30

# ── Load shape ────────────────────────────────────────────────────────────────
# Peak VUs during the sustained phase
MAX_VUS=30

# Time to ramp from 0 to MAX_VUS  (k6 duration string: 30s, 1m, 2m30s …)
RAMP_UP=1m

# How long to hold at MAX_VUS before the spike
SUSTAIN=3m

# VU count during the spike — increase until thresholds breach = breaking point
SPIKE_VUS=80

# How long to hold at SPIKE_VUS
SPIKE_DUR=2m

# ── Per-VU behaviour ─────────────────────────────────────────────────────────
# How many HTTP messages each VU sends per iteration
MSG_PER_VU=5

# Seconds between messages (float, e.g. 1.5)
MSG_INTERVAL=2

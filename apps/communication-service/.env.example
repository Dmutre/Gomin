NODE_ENV=development
GRPC_PORT=5001
HOST=localhost

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gomit-communication
DB_POOL_MIN=1
DB_POOL_MAX=10

RABBITMQ_URL=amqp://guest:guest@localhost:5672

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT: only auth issues (signs) tokens. This service must not hold private signing keys.
# When you add JWT verification for incoming gRPC calls, use @gomin/service-identity
# (e.g. MicroserviceIdentityGuard + ServiceIdentityClientModule): public keys are
# fetched from auth via GetPublicKeys, not copied into env here.

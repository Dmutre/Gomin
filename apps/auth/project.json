{
  "name": "auth",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/auth/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/auth"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "auth:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "auth:build:development"
        },
        "production": {
          "buildTarget": "auth:build:production"
        }
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node -r dotenv/config dist/apps/auth/main.js dotenv_config_path=apps/auth/.env"
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    },
    "db:migrate:make": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r tsx/cjs ../../node_modules/knex/bin/cli.js migrate:make --knexfile knexfile.ts {args.name}",
        "cwd": "apps/auth"
      }
    },
    "db:migrate:latest": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r tsx/cjs ../../node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
        "cwd": "apps/auth"
      }
    },
    "db:migrate:rollback": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r tsx/cjs ../../node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
        "cwd": "apps/auth"
      }
    },
    "db:migrate:status": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r tsx/cjs ../../node_modules/knex/bin/cli.js migrate:status --knexfile knexfile.ts",
        "cwd": "apps/auth"
      }
    },
    "db:seed:make": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r tsx/cjs ../../node_modules/knex/bin/cli.js seed:make --knexfile knexfile.ts {args.name}",
        "cwd": "apps/auth"
      }
    },
    "db:seed:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r tsx/cjs ../../node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts",
        "cwd": "apps/auth"
      }
    },
    "db:seed:service-identity": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -r tsx/cjs ../../node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts --specific=01_service_identities.ts",
        "cwd": "apps/auth"
      }
    },
    "jwt:demo": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx tools/scripts/jwt-demo.ts",
        "cwd": "apps/auth"
      }
    }
  }
}

NODE_ENV=development
GRPC_PORT=5000
HOST=localhost

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gomit-auth
DB_POOL_MIN=1
DB_POOL_MAX=10

RABBITMQ_URL=amqp://guest:guest@localhost:5672

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT signing keys - JSON array, use latest for signing
# Generate keys: openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt
JWT_SIGNING_KEYS=[{"keyId":"kid1","privateKey":"your-private-key-here","publicKey":"your-public-key-here"}]

# Service identity secrets for seeding the database. In production, these should be stored in a secure way.
SERVICE_IDENTITY_AUTH_SERVICE_SECRET=secret_placeholder
SERVICE_IDENTITY_COMMUNICATION_SECRET=secret_placeholder
SERVICE_IDENTITY_MEDIA_SECRET=secret_placeholder
SERVICE_IDENTITY_NOTIFICATION_SECRET=secret_placeholder
SERVICE_IDENTITY_USER_SECRET=secret_placeholder
SERVICE_IDENTITY_GATEWAY_SERVICE_SECRET=secret_placeholder

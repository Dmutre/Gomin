NODE_ENV=development
GRPC_PORT=5000
HOST=localhost

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gomit-auth
DB_POOL_MIN=1
DB_POOL_MAX=10

RABBITMQ_URL=amqp://guest:guest@localhost:5672

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT signing keys - JSON array, use latest for signing
# Generate keys: openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt
JWT_SIGNING_KEYS=[{"keyId":"kid1","privateKey":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----","publicKey":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"}]
